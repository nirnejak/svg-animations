{
  "name": "svg-animations",
  "description": "SVG Animations with Framer Motion",
  "version": "1.0.0",
  "author": "Jitendra Nirnejak <jeetnirnejak@gmail.com>",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "type-check": "tsc --pretty --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "@radix-ui/react-tooltip": "^1.2.8",
    "akar-icons": "^1.9.31",
    "dotenv": "^17.4.2",
    "motion": "^12.38.0",
    "next": "^16.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "babel-plugin-react-compiler": "^1.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.13",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css}": "biome check --fix --no-errors-on-unmatched"
  },
  "volta": {
    "node": "24.12.0"
  },
  "keywords": [
    "nextjs",
    "react",
    "typescript",
    "biome",
    "precommit"
  ],
